# Required for live intraday quotes.
FUGLE_API_KEY=

# Optional. FinMind can work without a token, but authenticated limits are higher.
FINMIND_TOKEN=

# Single-user fallback webhook.
DISCORD_WEBHOOK_URL=

# Multi-user webhook map. The YAML config references discord_webhook_key.
# Example: {"default":"https://discord.com/api/webhooks/...","alice":"https://discord.com/api/webhooks/..."}
DISCORD_WEBHOOKS_JSON=

# Optional public GitHub Pages URL, e.g. https://account.github.io/repository
REPORT_BASE_URL=
